# --- AWS IoT Core Configuration ---
AWS_ENDPOINT=your-endpoint.iot.your-region.amazonaws.com
CERT_FILE_NAME=your-certificate-file-name.pem.crt
KEY_FILE_NAME=your-private-key-file-name.pem.key

# --- AWS S3 Configuration (Optional) ---
S3_BUCKET_NAME=your-unique-s3-bucket-name
ENABLE_S3=false  # Set to "true" to enable S3 snapshot uploads (requires valid bucket)

# --- Flask Dashboard Configuration ---
SECRET_KEY=a-very-strong-and-random-secret-key-for-flask
