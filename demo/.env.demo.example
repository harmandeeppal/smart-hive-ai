# Smart Hive AI — Demo Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.demo in the project root and edit as
# needed. Default values work for local demo without any changes.
#
#   cp demo/.env.demo.example .env.demo

# ── MQTT ──────────────────────────────────────────────────────
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# ── Simulator ─────────────────────────────────────────────────
# How often telemetry is published (seconds)
TELEMETRY_INTERVAL=5
# How often a camera frame is published (seconds)
FRAME_INTERVAL=3

# ── Dashboard ─────────────────────────────────────────────────
# Flask session secret — change this for any real deployment
SECRET_KEY=demo-secret-key-change-for-production

# Password that protects the live demo login page
DEMO_PASSWORD=smarthive

# ── Demo mode ─────────────────────────────────────────────────
# Enables synthetic audio classification (no microphone needed)
DEMO_MODE=true

# ── Vision model ───────────────────────────────────────────────
# Lower threshold so demo sample frames trigger detections (0.0-1.0)
# Raise to 0.6-0.7 for production hardware to reduce false positives
VISION_CONFIDENCE_THRESHOLD=0.35

# ── Railway (cloud deployment only) ───────────────────────────
# Leave blank for local demo. Filled in during Phase 3 setup.
RAILWAY_API_TOKEN=
RAILWAY_ENVIRONMENT_ID=
RAILWAY_SIMULATOR_SERVICE_ID=
RAILWAY_AUDIO_SERVICE_ID=
